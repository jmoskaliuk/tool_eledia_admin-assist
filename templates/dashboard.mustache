{{!
    This file is part of Moodle - https://moodle.org/

    @template tool_adminassist/dashboard

    Admin Assist dashboard.
}}
<div class="tool-adminassist">
    <p class="lead">{{intro}}</p>

    {{#sections}}
        <section class="mb-5" aria-labelledby="tool-adminassist-section-{{id}}">
            <div class="mb-3">
                <h3 id="tool-adminassist-section-{{id}}" class="h4 mb-1">{{title}}</h3>
                <p class="text-muted mb-0">{{description}}</p>
            </div>

            <div class="row">
                {{#items}}
                    <div class="col-12 col-md-6 col-xl-4 mb-3">
                        <div class="card h-100">
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h4 class="h5 mb-0">{{title}}</h4>
                                    <span class="badge {{badgeclass}}">{{status}}</span>
                                </div>
                                <p class="text-muted flex-grow-1">{{description}}</p>
                                <a class="btn btn-secondary align-self-start" href="{{url}}">
                                    {{#str}} open, tool_adminassist {{/str}}
                                </a>
                            </div>
                        </div>
                    </div>
                {{/items}}
            </div>
        </section>
    {{/sections}}
</div>
